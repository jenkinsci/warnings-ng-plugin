{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>jenkinsci/renovate-config"
  ],
  "commitMessageAction": "Bump",
  "ignorePaths": ["src/**"],
  "packageRules": [
    {
      "allowedVersions": "< 10.0",
      "matchPackageNames": [
        "org.eclipse.collections:eclipse-collections{/,}**"
      ]
    }
  ]
}
