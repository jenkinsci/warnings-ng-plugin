<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form">

  <f:entry title="${%File pattern}" description="${%filePattern.description}" field="pattern">
    <f:textbox/>
  </f:entry>

  <f:entry title="${%Message pattern}" description="${%messagePattern.description}" field="messagePattern">
    <f:textbox/>
  </f:entry>

</j:jelly>
